<style>
  .signin-page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f3f4f6;
    padding: 24px;
  }

  .signin-card {
    width: 100%;
    max-width: 460px;
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    padding: 28px 24px;
    box-shadow: 0 1px 2px rgba(15, 23, 42, 0.08);
  }

  .signin-brand {
    text-align: center;
    margin-bottom: 24px;
  }

  .signin-brand img {
    width: 72px;
    height: auto;
    display: block;
    margin: 0 auto;
  }

  .signin-brand h1 {
    margin: 12px 0 0;
    font-size: 38px;
    font-weight: 600;
    line-height: 1.1;
  }

  .signin-form { display: grid; gap: 12px; }

  .signin-input {
    width: 100%;
    border: 1px solid #d1d5db;
    border-radius: 6px;
    padding: 12px 14px;
    font-size: 16px;
    color: #111827;
    box-sizing: border-box;
  }

  .signin-input:focus {
    outline: 2px solid rgba(15, 118, 110, 0.2);
    border-color: #0f766e;
  }

  .signin-submit {
    margin-top: 6px;
    width: 100%;
    border: 0;
    border-radius: 6px;
    padding: 12px 16px;
    font-size: 16px;
    font-weight: 500;
    color: #fff;
    background: linear-gradient(90deg, #134e4a 0%, #475569 100%);
    cursor: pointer;
  }

  .signin-links {
    margin-top: 18px;
    text-align: center;
  }

  .signin-links a { color: #334155; font-size: 14px; text-decoration: none; }
  .signin-links a:hover { color: #0f766e; }

  .signup-password-note {
    margin-top: 4px;
    color: #6b7280;
    font-size: 12px;
  }
</style>

<div class="signin-page">
  <div class="signin-card">
    <div class="signin-brand">
      <%= image_tag "logo.png", alt: "Rewards Portal" %>
      <h1 class="text-teal-200">Rewards Portal</h1>
    </div>

    <%= form_for(resource, as: resource_name, url: user_registration_path, html: { class: "signin-form" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <%= f.label :first_name, "First name" %>
      <%= f.text_field :first_name, autocomplete: "given-name", required: true, class: "signin-input" %>

      <%= f.label :last_name, "Last name" %>
      <%= f.text_field :last_name, autocomplete: "family-name", required: true, class: "signin-input" %>

      <%= f.label :contact_number, "Contact number" %>
      <%= f.telephone_field :contact_number, autocomplete: "tel", required: true, placeholder: "+63 9XX XXX XXXX", class: "signin-input" %>

      <%= f.label :email, "Email address" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "signin-input" %>

      <%= f.label :password, "Password" %>
      <%= f.password_field :password, autocomplete: "new-password", class: "signin-input" %>
      <% if @minimum_password_length %>
        <p class="signup-password-note"><%= @minimum_password_length %> characters minimum</p>
      <% end %>

      <%= f.label :password_confirmation, "Confirm password" %>
      <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "signin-input" %>

      <%= f.submit "Create account", class: "signin-submit" %>
    <% end %>

    <div class="signin-links">
      Already have an account?
      <%= link_to "Sign in", new_user_session_path %>
    </div>
  </div>
</div>
