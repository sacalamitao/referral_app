<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Salishsea: Referral Platform" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-zinc-100 text-slate-900">
    <% auth_page = devise_controller? && controller_name.in?(["sessions", "registrations"]) %>

    <% unless auth_page %>
      <header class="border-b border-teal-100 bg-white/95 backdrop-blur">
        <div class="mx-auto flex w-full max-w-6xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
          <div class="flex items-center gap-3">
            <div class="flex shrink-0 items-center justify-center rounded-full bg-teal-50 overflow-hidden"
                 style="width:40px;height:40px;max-width:40px;max-height:40px;">
              <%= image_tag header_logo_path,
                            alt: "Salish Sea Boating Referral Platform Logo",
                            width: 40,
                            height: 40,
                            style: "display:block;width:100%;height:100%;object-fit:contain;" %>
            </div>
            <div>
              <p class="text-sm text-teal-700">Salish Sea</p>
              <p class="text-base font-semibold text-teal-900">Boating Referral Platform</p>
            </div>
          </div>

          <div class="flex items-center gap-2">
            <% if user_signed_in? %>
              <p class="rounded-lg px-3 py-2 text-sm font-medium text-slate-700">
                <%= current_user&.first_name.present? ? "Welcome Back #{current_user.first_name.to_s.strip.split.first.titleize}!" : "Welcome Back!" %>
              </p>
              <%= button_to destroy_user_session_path,
                            method: :delete,
                            class: "inline-flex items-center rounded-lg border px-3 py-2 text-sm font-semibold shadow-sm",
                            form_class: "inline-flex",
                            style: "background-color:#0f172a;border-color:#0f172a;color:#ffffff;" do %>
                <span style="color:#ffffff;">Sign out</span>
              <% end %>
            <% else %>
              <%= link_to "Sign in", new_user_session_path,
                          class: "rounded-lg px-3 py-2 text-sm font-medium text-teal-800 hover:bg-teal-50" %>
              <%= link_to "Create account", new_user_registration_path,
                          class: "rounded-lg bg-teal-700 px-3 py-2 text-sm font-medium text-white hover:bg-teal-600" %>
            <% end %>
          </div>
        </div>
      </header>
    <% end %>

    <% if flash.any? %>
      <div class="fixed right-4 top-4 z-50 flex w-full max-w-sm flex-col gap-2 sm:right-6 sm:top-6">
        <% flash.each do |type, message| %>
          <% variant = flash_variant(type) %>
          <div class="group flex items-start gap-2 rounded-lg px-3 py-2 text-sm shadow-lg ring-1 backdrop-blur <%= variant[:wrapper] %>"
               data-auto-dismiss="true">
            <span class="mt-0.5 text-xs <%= variant[:icon] %>">●</span>
            <p class="line-clamp-2 flex-1 font-medium"><%= message %></p>
            <button type="button"
                    onclick="this.closest('[data-auto-dismiss]').remove()"
                    class="ml-1 text-base leading-none transition <%= variant[:close] %>"
                    aria-label="Dismiss alert">
              ×
            </button>
          </div>
        <% end %>
      </div>

      <script>
        document.querySelectorAll('[data-auto-dismiss]').forEach((toast) => {
          setTimeout(() => {
            toast.remove();
          }, 3200);
        });
      </script>
    <% end %>

    <main class="<%= auth_page ? 'min-h-screen' : 'mx-auto w-full max-w-6xl px-4 py-8 sm:px-6 lg:px-8' %>">

      <%= yield %>
    </main>
  </body>
</html>
